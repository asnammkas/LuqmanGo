rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Products ───────────────────────────────────────────────
    // Securing Production: All writes are now handled via Secure Cloud Functions.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;

      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ─── Categories ─────────────────────────────────────────────
    // Securing Production: All writes are now handled via Secure Cloud Functions.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Orders ─────────────────────────────────────────────────
    // Secure Production Logic:
    // Client-side creates/updates are fully DISABLED. 
    // Orders MUST be managed via secure Cloud Functions.
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (resource.data.customer.userId == request.auth.uid || isAdmin(request.auth.uid));
      allow write: if false;
    }

    // ─── Admins Collection ──────────────────────────────────────
    // Any authenticated user can check if they are an admin.
    // Write access is fully locked — manage via Firebase Console only.
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── User Profiles & Sub-collections ────────────────────────
    // Users can only read/write their own profile and nested data
    // (addresses, preferences, etc.).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Default Deny ───────────────────────────────────────────
    // Any collection not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
