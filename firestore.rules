rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── ADMINS Collection ──────────────────────────────────────────
    // Only admins can read their own doc (for status check).
    // No client-side writes — managed via Firebase Console only.
    match /admins/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ─── PRODUCTS Collection ────────────────────────────────────────
    // Anyone can read products (public storefront).
    // Only admins can create, update, or delete products.
    match /products/{productId} {
      allow read:  if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── ORDERS Collection ──────────────────────────────────────────
    // Authenticated users can create orders.
    // Users can only read their own orders (matched by customer.email or customer.userId).
    // Admins can read and update all orders (for status management).
    // No client-side deletes.
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin()
                    || (isAuthenticated() && resource.data.customer.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── USERS Collection (profiles) ────────────────────────────────
    // Users can only read and write their own profile document.
    // Admins cannot access user profiles (privacy).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // ─── ADDRESSES Sub-collection ─────────────────────────────────
      // Users can fully manage their own addresses.
      match /addresses/{addressId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // ─── Deny everything else ───────────────────────────────────────
    // Any collection not explicitly matched above is denied by default.
  }
}
