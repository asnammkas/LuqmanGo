rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Products ───────────────────────────────────────────────
    // Anyone can read products (public catalog).
    // Only admins can create, update, or delete.
    // Validates required fields and data types on write.
    match /products/{productId} {
      allow read: if true;

      allow create, update: if isAuthenticated()
        && isAdmin(request.auth.uid)
        && request.resource.data.title is string
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.category is string
        && request.resource.data.image is string;

      allow delete: if isAuthenticated() && isAdmin(request.auth.uid);
    }

    // ─── Categories ─────────────────────────────────────────────
    // Anyone can read categories (public catalog).
    // Only admins can create, update, or delete.
    match /categories/{categoryId} {
      allow read: if true;

      allow create, update: if isAuthenticated() 
        && isAdmin(request.auth.uid)
        && request.resource.data.name is string
        && request.resource.data.image is string;

      allow delete: if isAuthenticated() && isAdmin(request.auth.uid);
    }

    // ─── Orders ─────────────────────────────────────────────────
    // Secure Production Logic:
    // Client-side creates are now fully DISABLED. 
    // Orders MUST be created via the secure Firebase Cloud Function 'validateAndCreateOrder' 
    // to ensure price integrity and stock decrement transactions.
    match /orders/{orderId} {
      allow create: if isAdmin(request.auth.uid); // Admins can create via dashboard

      allow read: if isAuthenticated()
        && (resource.data.customer.userId == request.auth.uid || isAdmin(request.auth.uid));

      allow update, delete: if isAuthenticated() && isAdmin(request.auth.uid);
    }

    // ─── Admins Collection ──────────────────────────────────────
    // Any authenticated user can check if they are an admin.
    // Write access is fully locked — manage via Firebase Console only.
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── User Profiles & Sub-collections ────────────────────────
    // Users can only read/write their own profile and nested data
    // (addresses, preferences, etc.).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Default Deny ───────────────────────────────────────────
    // Any collection not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
