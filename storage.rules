rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Product Images ─────────────────────────────────────────
    // Anyone can view product images (public catalog assets).
    // Only admins can upload, update, or delete product images.
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── User Uploads (Profile Pictures, etc.) ──────────────────
    // Users can only access their own upload folder.
    // File size limited to 2MB, images only.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Default Deny ───────────────────────────────────────────
    // Block access to any path not matched above.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
